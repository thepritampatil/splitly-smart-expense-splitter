# Copy relevant vars to your environment or Railway/Render dashboard

# Profile: "dev" uses H2 in-memory DB, "prod" uses PostgreSQL
SPRING_PROFILE=dev

# JWT (change this in production — min 32 characters)
JWT_SECRET=splitly_super_secret_key_for_jwt_authentication_2024_production

# Production PostgreSQL (only needed for SPRING_PROFILE=prod)
DATABASE_URL=jdbc:postgresql://localhost:5432/splitlydb
DB_USERNAME=splitly
DB_PASSWORD=your_secure_password

# CORS: comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
